# Scan2Target — configuration reference
# ──────────────────────────────────────────────────────────────────────────────
# This file is for DOCUMENTATION ONLY.  Scan2Target no longer reads a .env
# file at runtime.  Configure the application via one of these methods:
#
#   1. Docker Secrets  (recommended for production)
#      Create a file  secrets/scan2target_secret_key  containing the key.
#      See docker-compose.yml for the full setup.
#
#   2. Environment variables passed to the container
#      docker run -e SCAN2TARGET_SECRET_KEY="…" …
#      or set them in docker-compose.yml under 'environment:'.
#
#   3. Your orchestrator's secret store
#      Kubernetes Secrets, Docker Swarm secrets, Vault, AWS Secrets Manager,
#      1Password, etc. — inject them as env vars or Docker Secrets.
#
# All variables use the prefix  SCAN2TARGET_
# ──────────────────────────────────────────────────────────────────────────────

# ── Security (required in production) ────────────────────────────────────────
# Master encryption key for stored target credentials.
# Generate with:  openssl rand -base64 32
# Preferred method: Docker Secret named "scan2target_secret_key"
SCAN2TARGET_SECRET_KEY=changeme-generate-a-secure-key

# Force authentication for all API endpoints (default: true)
SCAN2TARGET_REQUIRE_AUTH=true

# JWT token lifetime in seconds (default: 3600 = 1 hour)
# SCAN2TARGET_JWT_EXPIRATION=3600

# Restrict CORS to your frontend origin in production, e.g.:
# SCAN2TARGET_CORS_ORIGINS=["https://scanner.home"]

# ── Paths ─────────────────────────────────────────────────────────────────────
# SCAN2TARGET_DATA_DIR=/data
# SCAN2TARGET_DATABASE_PATH=/data/db/scan2target.db
# SCAN2TARGET_LOG_DIR=/var/log/scan2target
# SCAN2TARGET_TEMP_DIR=/tmp/scan2target/scans

# ── Logging ───────────────────────────────────────────────────────────────────
# SCAN2TARGET_LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Scanner timing ────────────────────────────────────────────────────────────
# How often the health monitor checks reachability (seconds, default: 60)
# SCAN2TARGET_HEALTH_CHECK_INTERVAL=60

# How often the device list is refreshed from the network (seconds, default: 30)
# SCAN2TARGET_SCANNER_CHECK_INTERVAL=30

# Timeout for subprocess calls like scanimage / airscan-discover (seconds, default: 15)
# SCAN2TARGET_COMMAND_TIMEOUT=15
